// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id         String       @id @default(uuid())
  email      String       @unique
  name       String
  password   String
  role       UserRole
  isActive   Boolean      @default(true)
  lastAccess DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime?    @updatedAt
  reports    UserReport[]

  @@map("users")
}

model Report {
  id              String            @id @default(uuid())
  externalId      String            @unique
  name            String
  webUrl          String
  embedUrl        String
  datasetId       String
  workspaceId     String
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime?         @updatedAt
  lastUpdate      DateTime?
  users           UserReport[]
  scheduleReports ScheduleReports[]
  errors          String?

  @@map("reports")
}

model UserReport {
  id       String @id @default(uuid())
  userId   String
  reportId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([userId, reportId])
  @@map("user_reports")
}

model ScheduleReports {
  id       String  @id @default(uuid())
  reportId String  @unique // Um relatório deve ter apenas uma configuração de agendamento
  isActive Boolean @default(true)

  // Horários comuns (Ex: ["08", "12", "18"])
  hoursCommon String[]

  // Regras de fechamento
  isClosingDays    Boolean  @default(false)
  closingDays      String[] // Dias do mês (Ex: ["01", "05", "28"])
  hoursClosingDays String[] // Horários específicos para esses dias

  // Auditoria
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("schedule_reports")
}
